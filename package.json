{
  "name": "gh-heatmap",
  "version": "0.1.0",
  "description": "Display GitHub contribution heatmap as an image in your terminal",
  "type": "module",
  "bin": {
    "gh-heatmap": "./dist/index.js"
  },
  "scripts": {
